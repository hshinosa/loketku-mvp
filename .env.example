# Loketku Environment Variables

# SQLite Database Path (optional)
# Default: ./data/loketku.db
# Untuk VPS production: /var/www/loketku/data/loketku.db
DATABASE_PATH=./data/loketku.db

# Server Configuration (optional)
# Default: PORT=4321, HOST=0.0.0.0
PORT=4321
HOST=0.0.0.0

# Hardcoded Auth Credentials (untuk development/demo)
# Login dengan:
# Email: admin@loketku.com
# Password: admin123
