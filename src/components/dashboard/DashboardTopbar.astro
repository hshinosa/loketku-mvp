---
import { UserMenu } from '../auth/UserMenu';
---

<header class="mb-6 rounded-3xl border border-slate-200/70 bg-white/80 px-4 py-4 shadow-[0_10px_28px_-24px_rgba(15,23,42,0.22)] backdrop-blur-md sm:px-5 sm:py-4.5">
  <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
    <div class="min-w-0 space-y-1.5">
      <div class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-500">
        Organizer Workspace
      </div>
      <div>
        <div class="min-w-0"><slot name="title" /></div>
        <div class="min-w-0"><slot name="description" /></div>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2 lg:justify-end">
      <slot name="actions" />
      <UserMenu client:load />
    </div>
  </div>
</header>
