---
import Layout from '../../../layouts/Layout.astro';
import { QRScanner } from '../../../components/tickets/QRScanner';
import DashboardTopbar from '../../../components/dashboard/DashboardTopbar.astro';

export const prerender = false;

const { id } = Astro.params;
---

<Layout title="Scanner Tiket - Loketku">
  <main className="container mx-auto px-4 py-6 sm:py-7">
    <DashboardTopbar>
      <h1 slot="title" className="text-3xl font-bold tracking-tight text-slate-900">Scanner Tiket</h1>
      <p slot="description" className="mt-1 text-slate-500">Arahkan kamera ke QR Code pada tiket pengunjung.</p>
      <div slot="actions">
        <button className="inline-flex h-10 items-center justify-center rounded-full border border-slate-200 bg-slate-50 px-4 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-100">
          Scanner Mode
        </button>
      </div>
    </DashboardTopbar>
    
    {id ? (
      <QRScanner eventId={id} client:only="react" />
    ) : (
      <div className="text-center text-destructive">ID Event tidak valid</div>
    )}
  </main>
</Layout>
